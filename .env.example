# App
APP_NAME=Enterprise Customer Service Agent
RUNTIME_ENV=production
LOG_LEVEL=INFO
API_PREFIX=/api/v1
ALLOWED_ORIGINS=https://console.example.com

# LLM: any OpenAI-compatible chat API.
LLM_PROVIDER=openai_compatible
LLM_API_KEY=
LLM_BASE_URL=https://llm-provider.example.com/v1
LLM_MODEL=<chat-model-name>
LLM_TEMPERATURE=0.2
LLM_TIMEOUT_SECONDS=60

# Embedding.
EMBEDDING_PROVIDER=openai_compatible
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://embedding-provider.example.com/v1
EMBEDDING_MODEL=<embedding-model-name>
EMBEDDING_DIMENSION=1024
EMBEDDING_TIMEOUT_SECONDS=60

# Database: MySQL async driver.
DATABASE_URL=mysql+aiomysql://<user>:<password>@<mysql-host>:3306/<database>?charset=utf8mb4

# Redis semantic cache.
SEMANTIC_CACHE_ENABLED=false
REDIS_URL=redis://:<password>@<redis-host>:6379/0
SEMANTIC_CACHE_TTL_SECONDS=3600
SEMANTIC_CACHE_THRESHOLD=0.90

# Vector knowledge base.
RAG_ENABLED=true
VECTOR_STORE_PROVIDER=qdrant
QDRANT_URL=https://qdrant.example.com
QDRANT_API_KEY=
QDRANT_COLLECTION=customer_service_knowledge
MILVUS_URI=https://milvus.example.com
MILVUS_TOKEN=
MILVUS_COLLECTION=customer_service_knowledge
RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.35

# Tenant cost governance.
COST_GOVERNANCE_ENABLED=true
TENANT_DEFAULT_TIER=standard
TENANT_TIER_MAP={"default":"standard","vip-demo":"premium","trial-demo":"basic"}
LLM_MODEL_BASIC=
LLM_MODEL_STANDARD=
LLM_MODEL_PREMIUM=
LLM_MODEL_DEGRADED=
BASIC_TENANT_RAG_TOP_K=3
STANDARD_TENANT_RAG_TOP_K=5
PREMIUM_TENANT_RAG_TOP_K=6
DEGRADED_RAG_TOP_K=2
DEGRADED_HISTORY_TURNS=3
BASIC_DAILY_TOKEN_BUDGET=50000
STANDARD_DAILY_TOKEN_BUDGET=300000
PREMIUM_DAILY_TOKEN_BUDGET=1500000
COST_WARNING_RATIO=0.8

# External web search tool.
SERPAPI_KEY=
SEARCH_RESULT_COUNT=5

# After-sales MCP service.
MCP_AFTER_SALES_ENABLED=false
MCP_AFTER_SALES_TRANSPORT=streamable_http
MCP_AFTER_SALES_URL=https://mcp-after-sales.example.com/mcp
MCP_AFTER_SALES_COMMAND=python
MCP_AFTER_SALES_ARGS=scripts/run_after_sales_mcp_server.py --stdio
MCP_TIMEOUT_SECONDS=20
MCP_APPROVAL_SIGNING_SECRET=
MCP_APPROVAL_ISSUER=customer-service-agent
MCP_APPROVAL_TOKEN_TTL_SECONDS=600

# Auth.
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
